# Public hostname. Leave unset (or "localhost") for local dev.
# DOMAIN=app.example.com

# Required to enable Let's Encrypt. Unset = dev mode (plain HTTP).
# ADMIN_EMAIL=you@example.com

# App and edge ports. In production the edge listens on 80 + 443
# automatically; only override these for local dev or non-default setups.
APP_PORT=3000
EDGE_PORT=8080

# Where the edge persists ACME account key + issued certs. Mount this as a
# volume in production so renewals survive container restarts.
CERT_DIR=./.certs

# Set to 1 for the first prod boot to use Let's Encrypt staging — useful to
# verify the flow without burning the 5-failures-per-hour prod rate limit.
# Unset (or set to 0) for the real cert.
# ACME_STAGING=1
